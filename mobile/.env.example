# Backend API base URL (must include the /api suffix).
# Production (Railway) is the built-in default, so you only need this for local dev:
#   - iOS simulator:     http://localhost:3001/api
#   - Android emulator:  http://10.0.2.2:3001/api
#   - Physical device:   http://<your-computer-LAN-IP>:3001/api
EXPO_PUBLIC_API_URL=https://ticketsystembackend.up.railway.app/api
