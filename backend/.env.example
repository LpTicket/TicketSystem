# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=ticketpro

# JWT
JWT_SECRET=change-me
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_EXPIRATION=7d

# Stripe
# Set STRIPE_MODE=production to use live keys, anything else uses test keys
STRIPE_MODE=test
STRIPE_SECRET_KEY_TEST=sk_test_xxx
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_xxx
STRIPE_WEBHOOK_SECRET_TEST=whsec_xxx
STRIPE_SECRET_KEY_PROD=sk_live_xxx
STRIPE_PUBLISHABLE_KEY_PROD=pk_live_xxx
STRIPE_WEBHOOK_SECRET_PROD=whsec_xxx_prod
# Legacy fallback (used if _TEST variant is not set)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email
RESEND_API_KEY=re_xxx
EMAIL_FROM=tickets@ticketpro.com

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001
UPLOAD_DIR=./uploads

# Cloudinary (Recommended for Render/PaaS)
# Get these for free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI Support
OPENAI_API_KEY=your_openai_api_key_here
